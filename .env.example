# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit credentials.

# ─── Database (Prisma) ────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string
# Use the "Transaction" pooler (port 6543) for API routes / serverless
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"

# Direct connection — only used by `prisma migrate dev` (never pooled)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Supabase → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# Server-only — never prefix with EXPO_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"
